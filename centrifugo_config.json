{
  "token_hmac_secret_key": "SECRET_KEY",
  "api_key": "SECRET_KEY",
  "allowed_origins": [
    "*"
  ],
  "engine": "redis",
  "proxies": [
    {
      "name": "connect",
      "endpoint": "http://chat-service:8080/api/v1/centrifugo/connect",
      "timeout": "3s"
    },
    {
      "name": "disconnect",
      "endpoint": "http://chat-service:8080/api/v1/centrifugo/disconnect",
      "timeout": "3s"
    }
  ],
  "namespaces": [
    {
      "name": "chat",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": true,
      "presence": true,
      "allow_presence_for_subscriber": true,
      "allow_presence_for_client": true,
      "join_leave": true,
      "force_push_join_leave": true,
      "history_size": 100,
      "history_ttl": "24h"
    },
    {
      "name": "groups",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": true,
      "presence": true,
      "allow_presence_for_subscriber": true,
      "allow_presence_for_client": true,
      "join_leave": true,
      "force_push_join_leave": true,
      "history_size": 100,
      "history_ttl": "24h"
    },
    {
      "name": "user",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": false,
      "presence": false,
      "join_leave": true,
      "history_size": 0
    },
    {
      "name": "user_notif",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": false,
      "presence": false,
      "join_leave": false,
      "history_size": 0
    }
  ]
}