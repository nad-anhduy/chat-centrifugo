{
  "token_hmac_secret_key": "SECRET_KEY",
  "api_key": "SECRET_KEY",
  "allowed_origins": ["*"],
  "engine": "redis",
  "redis": {
    "address": "redis:6379"
  },
  "namespaces": [
    {
      "name": "chat",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": true,
      "presence": true,
      "history_size": 100,
      "history_ttl": "24h",
      "publish": true
    }
  ]
}